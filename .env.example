# XION Chain
NEXT_PUBLIC_TREASURY_ADDRESS=xion1...
NEXT_PUBLIC_CHAIN_ID=xion-testnet-2
NEXT_PUBLIC_RPC_URL=https://rpc.xion-testnet-2.burnt.com:443
NEXT_PUBLIC_REST_URL=https://api.xion-testnet-2.burnt.com

# Contracts
NEXT_PUBLIC_CLEARANCE_CONTRACT=xion1...
NEXT_PUBLIC_NFT_CONTRACT=xion1...

# Feature flags
NEXT_PUBLIC_ENABLE_OAUTH3=false

# OAuth3 (TEE-attested OAuth proxy)
OAUTH3_BASE_URL=https://your-oauth3-instance.phala.cloud
NEXT_PUBLIC_OAUTH3_BASE_URL=https://your-oauth3-instance.phala.cloud

# Reclaim Protocol (zkTLS verification)
# Server-only secrets (never exposed to client)
RECLAIM_APP_ID=your-reclaim-app-id
RECLAIM_APP_SECRET=your-reclaim-app-secret
RECLAIM_PROVIDER_ID=your-reclaim-provider-id
NEXT_PUBLIC_RECLAIM_CLEARANCE_CONTRACT=xion1...
NEXT_PUBLIC_RECLAIM_NFT_CONTRACT=xion1...

# Droplinked Store
NEXT_PUBLIC_DROPLINKED_PRODUCT_ID=699fa86cb7618f1bcaeaf2a7
NEXT_PUBLIC_DROPLINKED_SHOP_ID=68b003f2c0fdcc16c19eb357

# Fallback modes
NEXT_PUBLIC_GOOGLE_BLOCKED=false
MAINTENANCE_MODE=false

# App
NEXT_PUBLIC_APP_URL=https://theredactedfile.com
NEXT_PUBLIC_EXPLORER_TX_URL=https://www.mintscan.io/xion-testnet/tx
